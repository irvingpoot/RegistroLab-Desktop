---
/**
 * @file estadisticas.astro
 * @description Panel de Inteligencia Clínica y Métricas Poblacionales.
 * * ESTRATEGIA DE DATOS:
 * - Se utiliza la función RPC `get_dashboard_stats` para delegar todo el 
 * procesamiento matemático (promedios, agregaciones, IMC) a la BD.
 * - Carga instantánea con consumo mínimo de datos.
 */

import Layout from "../layouts/Layout.astro"
import ReturnButton from "../components/ReturnButton.astro"
import { createClient } from "@supabase/supabase-js"

const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.SUPABASE_KEY
);

// 1. LLAMADA OPTIMIZADA A LA BASE DE DATOS (RPC)
// Solo descargamos un pequeño JSON ya procesado en lugar de miles de filas
const { data: statsRaw, error } = await supabase.rpc('get_dashboard_stats');
if (error) console.error("Error cargando estadísticas:", error);

const dbStats = statsRaw || {};

// 2. MAPEO DE DATOS PARA LA INTERFAZ
// Reconstruimos el objeto 'stats' y 'promedios' con la forma exacta 
// que espera tu HTML para no romper el diseño.
const stats = {
    total: dbStats.totalPacientes || 0,
    sueno: dbStats.sueno || 0,
    animo: dbStats.animo || 0,
    obesidad: dbStats.obesidad || 0,
    totalConImc: dbStats.totalConImc || 0,
    iah: {
        normal: dbStats.iahNormal || 0,
        leve: dbStats.iahLeve || 0,
        moderado: dbStats.iahModerado || 0,
        grave: dbStats.iahGrave || 0,
        total: dbStats.totalPoligrafias || 0
    }
};

const promedios = {
    edad: dbStats.edadPromedio || 0,
    epworth: dbStats.epworthPromedio || 0,
    beck: dbStats.beckPromedio || 0,
    bai: dbStats.baiPromedio || 0,
    psqi: dbStats.psqiPromedio || 0,
};

// El RPC devuelve arreglos de objetos: [{nombre: 'Insomnio', cantidad: 15}, ...]
// Los convertimos a tuplas [nombre, cantidad] para mantener compatibilidad con el HTML actual
const rankingSueno = (dbStats.topSueno || []).map((t: any) => [t.nombre, t.cantidad]);
const rankingAnimo = (dbStats.topAnimo || []).map((t: any) => [t.nombre, t.cantidad]);

// 3. CÁLCULO DE PORCENTAJES (Lógica de vista)
const pctSueno = stats.total ? Math.round((stats.sueno / stats.total) * 100) : 0;
const pctAnimo = stats.total ? Math.round((stats.animo / stats.total) * 100) : 0;
const pctObesidad = stats.totalConImc ? Math.round((stats.obesidad / stats.totalConImc) * 100) : 0;
---

<Layout title="Inteligencia Clínica | Lab-Somno">
    <ReturnButton href="/dashboard" text="Volver al dashboard" />

    <main class="max-w-7xl mx-auto pt-10 pb-20 px-4 animate-fade-in">
        
        <div class="mb-10 border-b border-gray-800 pb-6">
            <p class="text-blue-400 font-bold uppercase tracking-wider text-xs mb-1">Métricas del Laboratorio</p>
            <h1 class="text-4xl font-extrabold text-white mb-2">Estadisticas</h1>
            <p class="text-gray-400 text-sm">Análisis poblacional basado en los datos del laboratorio.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-gray-800/40 border border-gray-700/50 p-6 rounded-2xl">
                <p class="text-gray-400 text-xs font-bold uppercase mb-1">Total de Pacientes</p>
                <p class="text-4xl font-extrabold text-white">{stats.total}</p>
            </div>
            
            <div class="bg-blue-900/20 border border-blue-500/30 p-6 rounded-2xl">
                <p class="text-blue-400 text-xs font-bold uppercase mb-1">Perfil de Sueño</p>
                <div class="flex items-end gap-3">
                    <p class="text-4xl font-extrabold text-blue-300">{stats.sueno}</p>
                    <p class="text-sm text-blue-500 font-medium mb-1">({pctSueno}%)</p>
                </div>
            </div>

            <div class="bg-purple-900/20 border border-purple-500/30 p-6 rounded-2xl">
                <p class="text-purple-400 text-xs font-bold uppercase mb-1">Perfil de Ánimo</p>
                <div class="flex items-end gap-3">
                    <p class="text-4xl font-extrabold text-purple-300">{stats.animo}</p>
                    <p class="text-sm text-purple-500 font-medium mb-1">({pctAnimo}%)</p>
                </div>
            </div>

            <div class="bg-gray-800/40 border border-gray-700/50 p-6 rounded-2xl">
                <p class="text-gray-400 text-xs font-bold uppercase mb-1">Edad Promedio</p>
                <div class="flex items-end gap-2">
                    <p class="text-4xl font-extrabold text-gray-200">{promedios.edad}</p>
                    <p class="text-sm text-gray-500 font-medium mb-1">años</p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            
            <div class="bg-gray-900 border border-gray-800 p-8 rounded-3xl shadow-xl flex flex-col">
                <div class="flex justify-between items-start mb-2">
                    <div>
                        <h3 class="text-xl font-bold text-white flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                            Severidad de Apnea (IAH)
                        </h3>
                        <p class="text-xs text-gray-500 mt-1">Basado en {stats.iah.total} reportes de poligrafía.</p>
                    </div>
                </div>

                <div id="chart-iah" class="w-full h-full flex-grow flex items-center justify-center min-h-[250px]"></div>
            </div>

            <div class="bg-gray-900 border border-gray-800 p-8 rounded-3xl shadow-xl flex flex-col">
                <h3 class="text-xl font-bold text-white mb-2 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-pink-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                    Huella Clínica (Escalas Promedio)
                </h3>
                <p class="text-xs text-gray-500 mb-6">Severidad global ponderada al 100% en cuestionarios base.</p>

                <div class="flex-grow flex flex-col xl:flex-row items-center gap-6">
                    <div id="chart-radar" class="w-full xl:w-1/2 flex justify-center items-center min-h-[250px]"></div>

                    <div class="w-full xl:w-1/2 grid grid-cols-2 gap-3">
                        <div class={`p-4 rounded-xl border ${promedios.epworth > 10 ? 'bg-orange-900/10 border-orange-500/30' : 'bg-gray-800/40 border-gray-700/50'}`}>
                            <p class="text-gray-400 text-[10px] font-bold uppercase mb-1 truncate">Somnolencia</p>
                            <div class="flex items-end gap-1.5">
                                <span class={`text-2xl font-extrabold ${promedios.epworth > 10 ? 'text-orange-400' : 'text-white'}`}>{promedios.epworth}</span>
                                <span class="text-[10px] text-gray-500 font-medium pb-1">/ 24</span>
                            </div>
                        </div>

                        <div class={`p-4 rounded-xl border ${promedios.psqi > 5 ? 'bg-orange-900/10 border-orange-500/30' : 'bg-gray-800/40 border-gray-700/50'}`}>
                            <p class="text-gray-400 text-[10px] font-bold uppercase mb-1 truncate">Calidad Sueño</p>
                            <div class="flex items-end gap-1.5">
                                <span class={`text-2xl font-extrabold ${promedios.psqi > 5 ? 'text-orange-400' : 'text-white'}`}>{promedios.psqi}</span>
                                <span class="text-[10px] text-gray-500 font-medium pb-1">/ 21</span>
                            </div>
                        </div>

                        <div class="p-4 rounded-xl bg-gray-800/40 border border-gray-700/50">
                            <p class="text-gray-400 text-[10px] font-bold uppercase mb-1 truncate">Depresión</p>
                            <div class="flex items-end gap-1.5">
                                <span class="text-2xl font-extrabold text-white">{promedios.beck}</span>
                                <span class="text-[10px] text-gray-500 font-medium pb-1">/ 63</span>
                            </div>
                        </div>

                        <div class="p-4 rounded-xl bg-gray-800/40 border border-gray-700/50">
                            <p class="text-gray-400 text-[10px] font-bold uppercase mb-1 truncate">Ansiedad</p>
                            <div class="flex items-end gap-1.5">
                                <span class="text-2xl font-extrabold text-white">{promedios.bai}</span>
                                <span class="text-[10px] text-gray-500 font-medium pb-1">/ 63</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <div class="bg-gray-900 border border-gray-800 p-6 rounded-3xl shadow-xl">
                <h3 class="text-sm font-bold text-blue-400 uppercase tracking-wider mb-5">Top Alteraciones de Sueño</h3>
                <div class="space-y-4">
                    {rankingSueno.length > 0 ? rankingSueno.map(([nombre, count]) => (
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-gray-200 capitalize truncate pr-2">{nombre}</span>
                                <span class="text-blue-300 font-bold shrink-0">{count}</span>
                            </div>
                            <div class="w-full bg-gray-800 rounded-full h-1.5 overflow-hidden">
                                <div class="bg-blue-500 h-1.5 rounded-full opacity-80" style={`width: ${(count / stats.sueno) * 100}%`}></div>
                            </div>
                        </div>
                    )) : <p class="text-xs text-gray-600 italic">No hay datos suficientes.</p>}
                </div>
            </div>

            <div class="bg-gray-900 border border-gray-800 p-6 rounded-3xl shadow-xl">
                <h3 class="text-sm font-bold text-purple-400 uppercase tracking-wider mb-5">Top Trastornos de Ánimo</h3>
                <div class="space-y-4">
                    {rankingAnimo.length > 0 ? rankingAnimo.map(([nombre, count]) => (
                        <div>
                            <div class="flex justify-between text-sm mb-1">
                                <span class="text-gray-200 truncate pr-2" title={nombre}>{nombre}</span>
                                <span class="text-purple-300 font-bold shrink-0">{count}</span>
                            </div>
                            <div class="w-full bg-gray-800 rounded-full h-1.5 overflow-hidden">
                                <div class="bg-purple-500 h-1.5 rounded-full opacity-80" style={`width: ${(count / stats.animo) * 100}%`}></div>
                            </div>
                        </div>
                    )) : <p class="text-xs text-gray-600 italic">No hay datos suficientes.</p>}
                </div>
            </div>

            <div class="bg-gray-900 border border-gray-800 p-6 rounded-3xl shadow-xl flex flex-col justify-center">
                <h3 class="text-sm font-bold text-red-400 uppercase tracking-wider mb-5">Riesgo Fisiológico</h3>
                
                <div class="flex flex-col items-center justify-center p-6 bg-red-900/10 border border-red-500/20 rounded-2xl text-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-red-500 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                    <p class="text-gray-300 text-sm font-medium mb-1">Obesidad Clínica (IMC ≥ 30)</p>
                    <div class="flex items-end gap-2 justify-center">
                        <span class="text-5xl font-extrabold text-white">{pctObesidad}%</span>
                    </div>
                    <p class="text-xs text-gray-500 mt-2">De {stats.totalConImc} pacientes con talla y peso registrados.</p>
                </div>
            </div>

            <div class="flex col-span-3 gap-8">
                <div class="grow bg-gray-900 border border-gray-800 p-6 rounded-3xl shadow-xl flex flex-col">
                    <h3 class="text-sm font-bold text-blue-400 uppercase tracking-wider mb-1">Prevalencia: Sueño</h3>
                    <p class="text-xs text-gray-500 mb-4">Mapa de calor de alteraciones clínicas.</p>
                    
                    <div id="chart-treemap-sueno" class="w-full flex-grow flex items-center justify-center min-h-[200px]"></div>
                </div>

                <div class="grow bg-gray-900 border border-gray-800 p-6 rounded-3xl shadow-xl flex flex-col">
                    <h3 class="text-sm font-bold text-purple-400 uppercase tracking-wider mb-1">Prevalencia: Ánimo</h3>
                    <p class="text-xs text-gray-500 mb-4">Mapa de calor de trastornos psicológicos/psiquiátricos.</p>
                    
                    <div id="chart-treemap-animo" class="w-full flex-grow flex items-center justify-center min-h-[200px]"></div>
                </div>
            </div>

        </div>

    </main>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<script define:vars={{ iah: stats.iah, promedios, rankingSueno, rankingAnimo }}>
    document.addEventListener('DOMContentLoaded', function () {
        
        // ==========================================
        // 1. GRÁFICA DE BARRAS: SEVERIDAD IAH
        // ==========================================
        var iahOptions = {
            series: [{ name: 'Pacientes', data: [iah.normal, iah.leve, iah.moderado, iah.grave] }],
            chart: { type: 'bar', height: 280, toolbar: { show: false }, fontFamily: 'inherit', background: 'transparent' },
            plotOptions: { bar: { borderRadius: 6, horizontal: false, distributed: true, columnWidth: '55%' } },
            colors: ['#10b981', '#eab308', '#f97316', '#ef4444'],
            dataLabels: { enabled: true, style: { fontSize: '14px', fontWeight: 'bold', colors: ['#fff'] } },
            xaxis: { 
                categories: ['Normal (<5)', 'Leve (5-14)', 'Mod. (15-29)', 'Grave (≥30)'],
                labels: { style: { colors: '#9ca3af', fontWeight: 500, fontSize: '11px' } },
                axisBorder: { show: false }, axisTicks: { show: false }
            },
            yaxis: { labels: { style: { colors: '#6b7280' }, formatter: function (val) { return Math.round(val); } } },
            grid: { borderColor: '#374151', strokeDashArray: 4 },
            theme: { mode: 'dark' }, legend: { show: false }
        };
        new ApexCharts(document.querySelector("#chart-iah"), iahOptions).render();

        // ==========================================
        // 2. GRÁFICA DE RADAR: PERFIL CLÍNICO
        // ==========================================
        // Normalizamos los puntajes a porcentajes (0 - 100%)
        const radarData = [
            Math.round((promedios.epworth / 24) * 100) || 0, // Somnolencia
            Math.round((promedios.psqi / 21) * 100) || 0,    // Calidad Sueño
            Math.round((promedios.beck / 63) * 100) || 0,    // Depresión
            Math.round((promedios.bai / 63) * 100) || 0      // Ansiedad
        ];

        var radarOptions = {
            series: [{ name: 'Severidad', data: radarData }],
            chart: { type: 'radar', height: 300, toolbar: { show: false }, fontFamily: 'inherit', background: 'transparent' },
            stroke: { width: 2, colors: ['#ec4899'] }, // Rosa (Pink Tailwind)
            fill: { opacity: 0.2, colors: ['#ec4899'] },
            markers: { size: 4, colors: ['#fff'], strokeColors: '#ec4899', strokeWidth: 2 },
            xaxis: { 
                categories: ['Somnolencia', 'Mala Calidad Sueño', 'Depresión', 'Ansiedad'],
                labels: { show: true, style: { colors: ['#9ca3af', '#9ca3af', '#9ca3af', '#9ca3af'], fontSize: '10px', fontWeight: 600 } }
            },
            yaxis: { min: 0, max: 100, tickAmount: 4, labels: { show: false } }, // Ocultamos los números del centro del radar
            plotOptions: { radar: { polygons: { strokeColors: '#374151', strokeWidth: 1, connectorColors: '#374151' } } },
            tooltip: { theme: 'dark', y: { formatter: function(val) { return val + "% del máximo clínico" } } }
        };
        new ApexCharts(document.querySelector("#chart-radar"), radarOptions).render();

        // ==========================================
        // 3. GRÁFICAS TREEMAP: PREVALENCIAS
        // ==========================================
        
        // ApexCharts necesita los datos en formato { x: 'Nombre', y: Cantidad }
        const treemapSuenoData = rankingSueno.map(item => ({ x: item[0], y: item[1] }));
        const treemapAnimoData = rankingAnimo.map(item => ({ x: item[0], y: item[1] }));

        // Opciones base compartidas para no repetir código
        const baseTreemapOptions = {
            chart: { type: 'treemap', height: 220, toolbar: { show: false }, fontFamily: 'inherit', background: 'transparent' },
            theme: { mode: 'dark' },
            dataLabels: {
                enabled: true,
                style: { fontSize: '11px', fontWeight: 'bold' },
                // Mostramos el nombre y la cantidad de pacientes en cada cuadro
                formatter: function(text, op) { return [text, op.value + ' ptes'] }
            },
            plotOptions: {
                treemap: {
                    enableShades: true,
                    shadeIntensity: 0.5,
                    reverseNegativeShade: true,
                    colorScale: { inverse: false }
                }
            },
            tooltip: { theme: 'dark' }
        };

        // Renderizar Treemap Sueño (Tono Azul)
        var treemapSuenoOptions = {
            ...baseTreemapOptions,
            series: [{ data: treemapSuenoData }],
            colors: ['#3b82f6'], // blue-500
        };
        new ApexCharts(document.querySelector("#chart-treemap-sueno"), treemapSuenoOptions).render();

        // Renderizar Treemap Ánimo (Tono Morado)
        var treemapAnimoOptions = {
            ...baseTreemapOptions,
            series: [{ data: treemapAnimoData }],
            colors: ['#a855f7'], // purple-500
        };
        new ApexCharts(document.querySelector("#chart-treemap-animo"), treemapAnimoOptions).render();
    });
</script>